# ── Databáza (Supabase Postgres) ─────────────────────────────────────────
# Prečo Supabase (nie Neon): Fáza 2 = členský systém s QR vstupom —
# Supabase natívny auth + realtime ušetria neskoršiu prerábku.
#
# LOKÁLNE: tieto dve premenné vlož do `.env` (Prisma CLI číta iba .env;
# Next.js číta .env aj .env.local). Ostatné premenné patria do `.env.local`.
# Hodnoty nájdeš v Supabase dashboarde: projekt → Connect (tlačidlo hore).
#
# DATABASE_URL — "Transaction pooler" string (port 6543) + pgbouncer flagy;
# používa ho aplikácia za behu (Vercel serverless).
DATABASE_URL="postgresql://postgres.PROJECT-REF:HESLO@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL — "Direct connection" string (port 5432);
# používa ho iba `npx prisma migrate` (nie aplikácia).
DIRECT_URL="postgresql://postgres:HESLO@db.PROJECT-REF.supabase.co:5432/postgres"

# ── Stripe ───────────────────────────────────────────────────────────────
# TEST kľúče (sk_test_ / pk_test_) z https://dashboard.stripe.com/test/apikeys
# Produkčné kľúče AŽ PO právnej kontrole obchodných podmienok + doplnení IČO/DIČ.
STRIPE_SECRET_KEY="sk_test_PLACEHOLDER"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_PLACEHOLDER"
# Webhook signing secret — lokálne zo `stripe listen`, na Verceli z dashboardu.
STRIPE_WEBHOOK_SECRET="whsec_PLACEHOLDER"

# ── Web ──────────────────────────────────────────────────────────────────
# Verejná URL (pre Stripe success/cancel redirecty).
# Lokálne: http://localhost:3000 · Vercel: https://gladiator-ruby.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Admin prehľad objednávok (/admin/objednavky) — HTTP Basic Auth ───────
ADMIN_USER="admin"
ADMIN_PASSWORD="ZMENIT-NA-SILNE-HESLO"
